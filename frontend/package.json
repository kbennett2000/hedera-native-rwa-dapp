{
  "name": "hedera-native-rwa-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "prebuild": "npm --prefix .. run build",
    "predev": "npm --prefix .. run build",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run src",
    "banner": "node scripts/banner.mjs",
    "placeholders": "node scripts/placeholders.mjs",
    "prescreenshots": "npm --prefix .. run build",
    "screenshots": "node scripts/screenshots.mjs"
  },
  "dependencies": {
    "@hashgraph/hedera-wallet-connect": "^1.3.4",
    "@hashgraph/proto": "^2.25.0",
    "@hashgraph/sdk": "^2.81.0",
    "@walletconnect/modal": "^2.7.0",
    "@walletconnect/types": "^2.17.0",
    "@walletconnect/utils": "^2.17.0",
    "buffer": "^6.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "playwright": "^1.60.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.7"
  }
}
