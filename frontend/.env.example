# Frontend (investor app) configuration — Vite exposes only VITE_* vars to the client.
# Copy to .env and fill in. None of these are secrets (no operator key in the frontend).

# WalletConnect Cloud project id (https://cloud.walletconnect.com) — required to connect HashPack.
VITE_WALLETCONNECT_PROJECT_ID=

# Network + Mirror Node (testnet only for v1).
VITE_HEDERA_NETWORK=testnet
VITE_MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com

# The token + its audit topic. After running issuer scripts 01 and 02, copy these
# from the repo-root deployments.json (tokenId, topicId).
VITE_TOKEN_ID=
VITE_TOPIC_ID=
