# Hedera operator credentials (issuer/admin tooling — SDK scripts only).
# Copy to .env and fill in. NEVER commit .env or log these values.
#
# An ECDSA operator key is recommended: it is forward-compatible with the
# optional EVM / hybrid HTS-via-0x167 module (final cycle).
OPERATOR_ID=
OPERATOR_KEY=

# Network the SDK writes target.
HEDERA_NETWORK=testnet

# Mirror Node REST endpoint (reads — no wallet, no key).
MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com
